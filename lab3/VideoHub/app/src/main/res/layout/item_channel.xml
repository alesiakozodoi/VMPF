<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvChannelName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvChannelInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#888"/>
    </LinearLayout>
    <Button android:id="@+id/btnChannelSubscribe"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Підписатися" android:backgroundTint="#E94560" android:textSize="12sp"/>
</LinearLayout>
