<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvNotifMessage"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp"/>
        <TextView android:id="@+id/tvNotifDate"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#AAA"/>
    </LinearLayout>
    <Button android:id="@+id/btnMarkRead"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="✓" android:textSize="12sp" android:backgroundTint="#27AE60"/>
</LinearLayout>
